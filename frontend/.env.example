# ── VaultStay Frontend — copy to .env and fill in your values ──

# Contract address on Sepolia (auto-updated by deploy script)
VITE_CONTRACT_ADDRESS=

# Ethereum RPC URLs
VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_ANVIL_RPC_URL=http://127.0.0.1:8545

# Set to "true" for Sepolia, "false" for local Hardhat
VITE_USE_SEPOLIA=true

# WalletConnect Cloud Project ID (get from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Pinata IPFS (get from app.pinata.cloud)
VITE_PINATA_JWT=your_pinata_jwt
VITE_PINATA_API_KEY=your_pinata_api_key

# Supabase (get from supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
