{
    "compilerOptions": {
        "target": "es2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "*": [
                "node_modules/*"
            ]
        }
    },
    "include": [
        "./scripts",
        "./test",
        "./typechain-types"
    ],
    "files": [
        "./hardhat.config.ts"
    ],
    "references": [
        { "path": "./frontend" }
    ]
}